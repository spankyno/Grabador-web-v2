{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/types": ["../src/types/index.ts"]
    }
  },
  "include": ["src/**/*", "../src/types/**/*"],
  "exclude": ["node_modules", "dist"]
}
